# EAS Build upload ignore. When present, EAS uses THIS instead of .gitignore.
# Exclude local native folders + caches so EAS prebuilds fresh in the cloud
# (avoids uploading the local android/.gradle cache, which caused EBUSY lock errors).
node_modules/
.expo/
dist/
web-build/
# local native projects (regenerated by EAS cloud prebuild)
android/
ios/
# caches / junk
.gradle/
*.log
*.tsbuildinfo
.DS_Store
