{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://life-planer-opal.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://life-planer-opal.vercel.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6784142722"
      }
    }
  }
}
